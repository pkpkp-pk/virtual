# ---- Gemini (XAI layer) ----
# Required for /api/chat. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# The model is pinned in code to gemini-3.1-flash-lite (a cheap/fast Flash-tier
# model — this layer only translates intent and explains pre-computed results,
# no deep reasoning). If it's unavailable (503/429/timeout) the request degrades
# to the deterministic XAI panel instead of falling back to another model.

# ---- Google Maps (optional) ----
# Used only if you re-seed venue coordinates via geocoding. The bundled
# MetLife graph already has real coordinates, so this is optional.
GOOGLE_MAPS_API_KEY=

# ---- Firebase Admin SDK (server: Firestore + FCM + Remote Config) ----
# Option A: service account JSON env vars.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Option B: Application Default Credentials (e.g. gcloud auth / Cloud Functions runtime SA).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# When none of these are set, the app falls back to deterministic jitter(t)
# and dev in-memory state — the demo still works, the UI is still live.

# ---- Browser Firebase (events feed + FCM + Auth + offline persistence) ----
# Paste the firebaseConfig object from the Firebase console (include
# messagingSenderId for FCM). If unset, the frontend polls /api/crowd and uses
# client-side alert detection (dev fallback).
# NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"...","messagingSenderId":"..."}
# Fallback individual vars (only if NEXT_PUBLIC_FIREBASE_CONFIG is unset):
# NEXT_PUBLIC_FB_PROJECT_ID=
# NEXT_PUBLIC_FB_API_KEY=
# NEXT_PUBLIC_FB_APP_ID=

# ---- FCM web push (required for push notifications) ----
# Generate a VAPID key pair in Firebase console > Project settings > Cloud Messaging > Web push.
NEXT_PUBLIC_VAPID_KEY=
# Also edit public/firebase-messaging-sw.js and replace the __FIREBASE_*__ placeholders.

# ---- App Check (optional, Phase 4) ----
# reCAPTCHA v3 site key from the Firebase console > App Check.
# NEXT_PUBLIC_APPCHECK_RECAPTCHA_SITE_KEY=

# ---- Manual admin tick ----
# Secret required on the X-Cron-Secret header to call POST /api/sim/tick (a
# manual force-detect trigger; no scheduler drives it on Spark).
# Generate with: openssl rand -hex 32
SIM_CRON_SECRET=

# ---- Organizer view (Phase 6) ----
# Secret required on the X-Ops-Secret header to read GET /api/ops. If unset,
# /api/ops is open (fine for a demo — the data is non-sensitive aggregates).
# Generate with: openssl rand -hex 32
# OPS_SECRET=

# ---- Remote Config (Phase 3, console-configured, no env var) ----
# In the Firebase console > Remote Config, set these keys (server reads them
# with a 60s cache, falling back to defaults if unset):
#   overCapacityThreshold (number, default 0.9) — alert threshold
#   calmThreshold          (number, default 0.7) — forecast "clears" threshold
#   forecastHorizonMin     (number, default 15) — minutes ahead to project

# ---- Scenario clock (optional) ----
# Epoch (ms) for the crowd scenario clock. Defaults to process start - 50 min,
# so a demo opens ~10 min before kickoff and watches the surge build.
# SCENARIO_EPOCH_MS=
